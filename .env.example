# Server identity
CS2_SERVERNAME="GG SERVER"
CS2_PORT=27015

# GSLT from Steam - required for public servers
SRCDS_TOKEN="568D0FE......8C61"  #Get this info on Steam

# RCON password for remote administration
CS2_RCONPW="SamplePassword"

# Game mode settings
# 0 = Casual, 1 = Competitive, 2 = Wingman, 3 = Deathmatch
CS2_GAMETYPE=0
CS2_GAMEMODE=1

# Map settings
CS2_MAPNAME="de_dust2"
CS2_MAPGROUP="mg_active"

# Player settings
CS2_MAXPLAYERS=12
CS2_BOT_DIFFICULTY=2
CS2_BOT_QUOTA=0
CS2_BOT_QUOTA_MODE="fill"

# Network settings
CS2_LAN=0
CS2_CHEATS=0

# Server password (empty for public)
CS2_PW="SamplePassword2"

# Additional server cvars
CS2_ADDITIONAL_ARGS="+host_workshop_map 37312345678" # Get this info on steam